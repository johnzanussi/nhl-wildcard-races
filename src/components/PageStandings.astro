---
import Layout from '@/layouts/Layout.astro';
import Standings from '@/components/Standings.astro';
import type { ConferenceKey } from '@/data/Standings';

type Props = {
    isPlayoffs?: boolean;
};

const { isPlayoffs = false } = Astro.props;

const conference = Astro.params.conference as ConferenceKey;
const conferenceLabel = conference === 'east' ? 'Eastern' : 'Western';
const siteUrl = 'https://nhlwildcard.com';
const conferenceUrl = `${siteUrl}/${conference}`;

let pageTitle: string;
let pageDescription: string;
let breadcrumbs: { name: string; item: string }[];

if (isPlayoffs) {
    pageTitle = `${conferenceLabel} Conference Playoff Picture 2025-26 | NHL Wild Card Races`;
    pageDescription = `See which ${conferenceLabel} Conference teams have clinched NHL playoff spots for 2025-26.`;
    breadcrumbs = [
        { name: `${conferenceLabel} Conference`, item: conferenceUrl },
        { name: 'Playoff Picture', item: `${conferenceUrl}/playoffs` },
    ];
} else {
    const divisionsText = conference === 'east'
        ? 'Metropolitan and Atlantic Divisions'
        : 'Central and Pacific Divisions';
    pageTitle = `${conferenceLabel} Conference Wild Card Standings 2025-26 | NHL Wild Card Races`;
    pageDescription = `Track the 2025-26 ${conferenceLabel} Conference NHL wild card race. Live standings for teams battling for playoff spots in the ${divisionsText}.`;
    breadcrumbs = [
        { name: `${conferenceLabel} Conference`, item: conferenceUrl },
    ];
}
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>

	<Standings
        conference={conference}
        isPlayoffs={isPlayoffs}
    />

</Layout>
