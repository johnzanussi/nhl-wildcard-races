---
export type Props = {
    content: string;
    placement?: 'top' | 'bottom';
    as?: string;
    class?: string;
    [key: string]: unknown;
};

const { content, placement = 'bottom', as: Tag = 'span', class: className, ...rest } = Astro.props;
---

<Tag
    data-tooltip={content}
    data-tooltip-placement={placement}
    class={className}
    {...rest}
>
    <slot />
</Tag>

<script>
    (function () {
        function load() {
            import('@/scripts/tooltip');
        }
        if (typeof requestIdleCallback !== 'undefined') {
            requestIdleCallback(load, { timeout: 2000 });
        } else {
            setTimeout(load, 1);
        }
    })();
</script>
