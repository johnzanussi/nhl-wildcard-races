---
import { type TeamStanding } from '@/data/Standings';

import Logo from '@/components/Team/Logo.astro';
import TeamName from '@/components/TeamName.astro';
import Stats from '@/components/Team/Stats.astro';

type Props = {
    team: TeamStanding;
};

const { team } = Astro.props;


const getRankDisplay = (t: TeamStanding): { primary: string | number; sub?: string } => {
    if (t.isInPlayoffs) {
        return { primary: t.divisionPlace, sub: t.divisionShort };
    }
    if (t.isInWildCard) {
        return { primary: t.wildCardPlace, sub: 'WC' };
    }
    return { primary: t.wildCardPlace };
};

const rankDisplay = getRankDisplay(team);
---

<div
    class:list={[
        'standings-row-grid grid items-center gap-x-1',
        'standings-row-base rounded-l-lg',
        {
            'opacity-50': team.isEliminated,
        },
    ]}
    data-team-code={team.teamCode}
>

    <div class="flex flex-col items-center justify-center">
        <span class="text-md font-bold md:text-xl leading-none">
            {rankDisplay.primary}
        </span>
        {rankDisplay.sub && (
            <span class="text-[10px] font-semibold opacity-60 leading-none mt-0.5 md:text-xs">
                {rankDisplay.sub}
            </span>
        )}
    </div>

    <div class="flex flex-col md:flex-row md:items-center relative">
        <div class="flex items-center gap-1">
            <Logo
                teamCode={team.teamCode}
                size={25}
                loading="eager"
            />
            <div class=" flex flex-row items-baseline gap-1.5 md:flex-col md:items-start md:gap-0 justify-center">
                <TeamName
                    teamCode={team.teamCode}
                    class="text-xs md:text-sm"
                />
            </div>
        </div>
        {team.pointsBack > 0 && (
            <span class="absolute -bottom-4 left-0 text-[10px] opacity-60 leading-none">
                {team.pointsBack} points back
            </span>
        )}
    </div>

    <Stats
        pts={team.points}
        gr={team.gamesRemaining}
        rw={team.regulationWins}
        ppr={team.potentialPointsRemaining}
    />

</div>
