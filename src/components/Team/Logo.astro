---
import { Image } from 'astro:assets';
import { type TeamCode } from '@/data/nhl';
import { type LogoType, type LogoProvider, getTeamLogoUrl, getTeamName } from '@/data/Teams.ts';

type Props = {
    teamCode: TeamCode;
    type?: LogoType;
    size?: number;
    provider?: LogoProvider;
    loading?: 'lazy' | 'eager';
};

const {
    teamCode,
    type,
    size = 60,
    provider = 'espn',
    loading = 'lazy',
} = Astro.props;

const imageUrl = getTeamLogoUrl(teamCode, provider, type);
const teamName = getTeamName(teamCode);
---

<Image
    src={imageUrl}
    alt={`${teamName} logo`}
    width={size}
    height={size}
    densities={[1, 2, 3]}
    loading={loading}
    class="inline w-(--logo-size)"
    style={`--logo-size: ${size}px`}
/>
