---
import Tooltip from '@/components/Tooltip.astro';

const statColumns = [
    { key: 'PTS', tooltip: 'Total Points' },
    { key: 'GR', tooltip: 'Games Remaining' },
    { key: 'RW', tooltip: 'Regulation Wins' },
    { key: 'PPR', tooltip: 'Potential Points Remaining' },
];
---

<div class="flex items-center gap-x-1 border-b bg-base-100 border-base-300 py-1.5 md:py-2 mb-1 md:mb-2">
    <div class="shrink-0 grid items-center gap-x-1 standings-header-fixed-grid px-1 sm:px-2" style="width: var(--standings-left-column-width)">
        <div class="standings-header-cell w-(--standings-col-rank)">
            Rank
        </div>
        <div class="standings-header-cell w-(--standings-col-team) standings-header-team-cell">
            Team
        </div>
        {statColumns.map(({ key, tooltip }) => (
            <Tooltip
                as="div"
                data-stat-cell
                content={tooltip}
                class="standings-header-cell w-(--standings-col-stat) justify-center"
            >
                <span class="cursor-help underline decoration-dotted decoration-current/60">{key}</span>
            </Tooltip>
        ))}
    </div>
    <div class="standings-header-cell ps-2 sm:ps-3 flex justify-between min-w-0 flex-1">
        <span>Schedule</span>
    </div>
</div>
